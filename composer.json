  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94"
  },
  "require": {
    "psr/log": "^3.0",
    "monolog/monolog": "^3.10",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1"
  }
}
